        "# ==========================================================\n",
        "# FINAL DECK VISUALIZATIONS — CLEANED DATA VERSION\n",
        "# ==========================================================\n",
        "\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "import requests\n",
        "import time\n",
        "import os\n",
        "\n",
        "os.makedirs(\"presentation_charts\", exist_ok=True)\n",
        "\n",
        "# -----------------------------\n",
        "# LOAD CLEANED DATA\n",
        "# -----------------------------\n",
        "sessions = pd.read_csv(\"cleaned_sessions.csv\")\n",
        "stations = pd.read_csv(\"cleaned_stations.csv\")\n",
        "vehicles = pd.read_csv(\"cleaned_vehicles.csv\")\n",
        "operators = pd.read_csv(\"cleaned_operators.csv\")\n",
        "\n",
        "# -----------------------------\n",
        "# STYLE\n",
        "# -----------------------------\n",
        "plt.rcParams.update({\n",
        "    \"figure.facecolor\": \"white\",\n",
        "    \"axes.facecolor\": \"white\",\n",
        "    \"axes.edgecolor\": \"#D9DEE7\",\n",
        "    \"axes.labelcolor\": \"#1F2937\",\n",
        "    \"text.color\": \"#1F2937\",\n",
        "    \"xtick.color\": \"#374151\",\n",
        "    \"ytick.color\": \"#374151\",\n",
        "    \"axes.titleweight\": \"bold\",\n",
        "    \"axes.titlesize\": 15,\n",
        "    \"axes.labelsize\": 12,\n",
        "    \"font.size\": 11\n",
        "})\n",
        "\n",
        "NAVY = \"#1D4E89\"\n",
        "BLUE = \"#2E86DE\"\n",
        "LIGHT_BLUE = \"#85C1E9\"\n",
        "ORANGE = \"#E67E22\"\n",
        "GREEN = \"#27AE60\"\n",
        "RED = \"#C0392B\"\n",
        "GRAY = \"#6B7280\"\n",
        "DARK = \"#1F2937\"\n",
        "\n",
        "# -----------------------------\n",
        "# PREP DATA\n",
        "# -----------------------------\n",
        "sessions[\"session_start\"] = pd.to_datetime(sessions[\"session_start\"], errors=\"coerce\")\n",
        "sessions[\"session_end\"] = pd.to_datetime(sessions[\"session_end\"], errors=\"coerce\")\n",
        "sessions = sessions.dropna(subset=[\"session_start\"]).copy()\n",
        "\n",
        "sessions[\"date\"] = sessions[\"session_start\"].dt.date\n",
        "sessions[\"month\"] = sessions[\"session_start\"].dt.to_period(\"M\").astype(str)\n",
        "\n",
        "sessions[\"station_id\"] = sessions[\"station_id\"].astype(str).str.strip()\n",
        "stations[\"station_id\"] = stations[\"station_id\"].astype(str).str.strip()\n",
        "\n",
        "print(\"Cleaned sessions:\", sessions.shape)\n",
        "print(\"Cleaned stations:\", stations.shape)\n",
        "\n",
        "# ==========================================================\n",
        "# API SETUP: OPEN-METEO WEATHER DATA\n",
        "# ==========================================================\n",
        "\n",
        "weather_rows = []\n",
        "\n",
        "for _, row in stations.iterrows():\n",
        "    station_id = row[\"station_id\"]\n",
        "    lat = row[\"latitude\"]\n",
        "    lon = row[\"longitude\"]\n",
        "\n",
        "    url = \"https://archive-api.open-meteo.com/v1/archive\"\n",
        "    params = {\n",
        "        \"latitude\": lat,\n",
        "        \"longitude\": lon,\n",
        "        \"start_date\": \"2025-01-01\",\n",
        "        \"end_date\": \"2025-12-31\",\n",
        "        \"daily\": \"temperature_2m_mean,precipitation_sum\",\n",
        "        \"timezone\": \"America/New_York\"\n",
        "    }\n",
        "\n",
        "    response = requests.get(url, params=params, timeout=30)\n",
        "    data = response.json()\n",
        "    daily = data.get(\"daily\", {})\n",
        "\n",
        "    station_weather = pd.DataFrame({\n",
        "        \"date\": daily.get(\"time\", []),\n",
        "        \"temperature_2m_mean\": daily.get(\"temperature_2m_mean\", []),\n",
        "        \"precipitation_sum\": daily.get(\"precipitation_sum\", [])\n",
        "    })\n",
        "\n",
        "    station_weather[\"station_id\"] = station_id\n",
        "    weather_rows.append(station_weather)\n",
        "\n",
        "    print(f\"Pulled weather for {station_id}\")\n",
        "    time.sleep(0.2)\n",
        "\n",
        "weather_df = pd.concat(weather_rows, ignore_index=True)\n",
        "weather_df[\"date\"] = pd.to_datetime(weather_df[\"date\"], errors=\"coerce\").dt.date\n",
        "\n",
        "sessions_with_weather = sessions.merge(\n",
        "    weather_df,\n",
        "    on=[\"station_id\", \"date\"],\n",
        "    how=\"left\"\n",
        ")\n",
        "\n",
        "sessions_with_weather.to_csv(\"sessions_with_weather.csv\", index=False)\n",
        "\n",
        "print(\"sessions_with_weather:\", sessions_with_weather.shape)\n",
        "\n",
        "# ==========================================================\n",
        "# 1. DAILY CHARGING DEMAND\n",
        "# ==========================================================\n",
        "\n",
        "daily_sessions = (\n",
        "    sessions.groupby(\"date\")\n",
        "    .size()\n",
        "    .reset_index(name=\"session_count\")\n",
        "    .sort_values(\"date\")\n",
        ")\n",
        "\n",
        "daily_sessions[\"date\"] = pd.to_datetime(daily_sessions[\"date\"])\n",
        "daily_sessions[\"rolling_7d\"] = daily_sessions[\"session_count\"].rolling(7, center=True).mean()\n",
        "\n",
        "peak_day = daily_sessions.loc[daily_sessions[\"session_count\"].idxmax()]\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(13, 6))\n",
        "\n",
        "ax.plot(daily_sessions[\"date\"], daily_sessions[\"session_count\"],\n",
        "        color=LIGHT_BLUE, linewidth=1.5, alpha=0.45, label=\"Daily Sessions\")\n",
        "\n",
        "ax.plot(daily_sessions[\"date\"], daily_sessions[\"rolling_7d\"],\n",
        "        color=NAVY, linewidth=3, label=\"7-Day Rolling Average\")\n",
        "\n",
        "ax.scatter(peak_day[\"date\"], peak_day[\"session_count\"], color=RED, s=60)\n",
        "\n",
        "ax.annotate(\n",
        "    f'Peak: {int(peak_day[\"session_count\"])}',\n",
        "    (peak_day[\"date\"], peak_day[\"session_count\"]),\n",
        "    xytext=(10, 10),\n",
        "    textcoords=\"offset points\",\n",
        "    fontsize=10,\n",
        "    color=RED\n",
        ")\n",
        "\n",
        "ax.set_title(\"Charging Demand Stayed Stable Most of the Year, with Clear Surge Periods\")\n",
        "ax.set_xlabel(\"Date\")\n",
        "ax.set_ylabel(\"Number of Sessions\")\n",
        "ax.grid(axis=\"y\", linestyle=\"--\", alpha=0.25)\n",
        "ax.legend(frameon=False)\n",
        "\n",
        "for spine in [\"top\", \"right\"]:\n",
        "    ax.spines[spine].set_visible(False)\n",
        "\n",
        "plt.xticks(rotation=45)\n",
        "plt.tight_layout()\n",
        "plt.savefig(\"presentation_charts/01_daily_charging_demand.png\", dpi=300, bbox_inches=\"tight\")\n",
        "plt.show()\n",
        "\n",
        "# ==========================================================\n",
        "# 2. API VISUAL: TEMPERATURE AND CHARGING\n",
        "# ==========================================================\n",
        "\n",
        "daily_temp = (\n",
        "    sessions_with_weather.groupby(\"date\")\n",
        "    .agg(\n",
        "        session_count=(\"session_id\", \"count\"),\n",
        "        avg_temp=(\"temperature_2m_mean\", \"mean\")\n",
        "    )\n",
        "    .dropna()\n",
        "    .reset_index()\n",
        ")\n",
        "\n",
        "daily_temp[\"temp_bin\"] = pd.cut(\n",
        "    daily_temp[\"avg_temp\"],\n",
        "    bins=np.arange(-10, 36, 5)\n",
        ")\n",
        "\n",
        "temp_summary = (\n",
        "    daily_temp.groupby(\"temp_bin\", observed=False)[\"session_count\"]\n",
        "    .mean()\n",
        "    .reset_index()\n",
        ")\n",
        "\n",
        "temp_summary[\"temp_range\"] = temp_summary[\"temp_bin\"].astype(str)\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(11, 6))\n",
        "\n",
        "bars = ax.bar(temp_summary[\"temp_range\"], temp_summary[\"session_count\"], color=BLUE)\n",
        "\n",
        "for bar in bars:\n",
        "    h = bar.get_height()\n",
        "    if pd.notna(h):\n",
        "        ax.text(bar.get_x() + bar.get_width()/2, h + 0.8,\n",
        "                f\"{h:.1f}\", ha=\"center\", fontsize=9)\n",
        "\n",
        "ax.set_title(\"Charging Demand Was Highest on Warmer Days\")\n",
        "ax.set_xlabel(\"Average Daily Temperature Range (°C)\")\n",
        "ax.set_ylabel(\"Average Daily Charging Sessions\")\n",
        "ax.grid(axis=\"y\", linestyle=\"--\", alpha=0.25)\n",
        "\n",
        "for spine in [\"top\", \"right\"]:\n",
        "    ax.spines[spine].set_visible(False)\n",
        "\n",
        "plt.xticks(rotation=30)\n",
        "plt.tight_layout()\n",
        "plt.savefig(\"presentation_charts/02_temperature_charging.png\", dpi=300, bbox_inches=\"tight\")\n",
        "plt.show()\n",
        "\n",
        "# ==========================================================\n",
        "# 3. API VISUAL: RAINY VS DRY DAYS\n",
        "# ==========================================================\n",
        "\n",
        "daily_rain = (\n",
        "    sessions_with_weather.groupby(\"date\")\n",
        "    .agg(\n",
        "        session_count=(\"session_id\", \"count\"),\n",
        "        precipitation=(\"precipitation_sum\", \"mean\")\n",
        "    )\n",
        "    .dropna()\n",
        "    .reset_index()\n",
        ")\n",
        "\n",
        "daily_rain[\"day_type\"] = np.where(\n",
        "    daily_rain[\"precipitation\"] > 0,\n",
        "    \"Rainy Day\",\n",
        "    \"Dry Day\"\n",
        ")\n",
        "\n",
        "rain_summary = (\n",
        "    daily_rain.groupby(\"day_type\")[\"session_count\"]\n",
        "    .mean()\n",
        "    .reindex([\"Dry Day\", \"Rainy Day\"])\n",
        "    .reset_index()\n",
        ")\n",
