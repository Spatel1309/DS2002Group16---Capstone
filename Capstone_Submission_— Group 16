    {
      "cell_type": "code",
      "source": [
        "# Fix datetime columns with mixed formats\n",
        "sessions[\"session_start\"] = pd.to_datetime(sessions[\"session_start\"], format=\"mixed\", errors=\"coerce\")\n",
        "sessions[\"session_end\"]   = pd.to_datetime(sessions[\"session_end\"],   format=\"mixed\", errors=\"coerce\")\n",
        "\n",
        "# Drop rows with missing dates\n",
        "sessions = sessions.dropna(subset=[\"session_start\", \"session_end\"])\n",
        "\n",
        "# Drop negative kwh rows\n",
        "sessions = sessions[sessions[\"kwh_delivered\"] >= 0]\n",
        "\n",
        "# Fix cost_usd to numeric\n",
        "sessions[\"cost_usd\"] = pd.to_numeric(sessions[\"cost_usd\"], errors=\"coerce\")\n",
        "\n",
        "# Fill missing numerics with median\n",
        "sessions[\"kwh_delivered\"] = sessions[\"kwh_delivered\"].fillna(sessions[\"kwh_delivered\"].median())\n",
        "sessions[\"cost_usd\"]      = sessions[\"cost_usd\"].fillna(sessions[\"cost_usd\"].median())\n",
        "\n",
        "# Fill missing connector_used with mode\n",
        "sessions[\"connector_used\"] = sessions[\"connector_used\"].fillna(sessions[\"connector_used\"].mode()[0])\n",
        "\n",
        "# Fill missing vehicle_id with \"Unknown\"\n",
        "sessions[\"vehicle_id\"] = sessions[\"vehicle_id\"].fillna(\"Unknown\")\n",
        "\n",
        "# Standardize vehicle IDs to VH-XXX format\n",
        "vehicle_id_map = {\n",
        "    \"VEH#0001\": \"VH-001\", \"VEH#0002\": \"VH-002\", \"VEH#0003\": \"VH-003\",\n",
        "    \"VEH#0004\": \"VH-004\", \"VEH#0005\": \"VH-005\", \"VEH#0006\": \"VH-006\",\n",
